NODE_ENV=production
DATABASE_URL=postgresql://talentrank:change_me@postgres:5432/talentrank
TALENTRANK_USE_PRISMA=true

TALENTRANK_AUTH_SECRET=replace_with_32_plus_random_bytes
TALENTRANK_BOOTSTRAP_EMAIL=admin@yourcompany.com
TALENTRANK_BOOTSTRAP_PASSWORD=temporary_first_admin_password_rotate_after_setup

TALENTRANK_STORAGE_KEY=replace_with_32_plus_random_bytes
TALENTRANK_STORAGE_PROVIDER=external
TALENTRANK_STORAGE_UPLOAD_URL=https://storage-gateway.example.com/upload
TALENTRANK_STORAGE_TOKEN=replace_if_gateway_requires_bearer

TALENTRANK_MALWARE_SCAN_URL=https://scanner.example.com/scan
TALENTRANK_MALWARE_SCAN_KEY=replace_if_scanner_requires_bearer

OCR_API_URL=https://ocr.example.com/extract
OCR_API_KEY=replace_if_ocr_requires_bearer

OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=256
TALENTRANK_MAX_BATCH_FILES=50
