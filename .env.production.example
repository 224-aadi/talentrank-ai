NODE_ENV=production
TALENTRANK_APP_URL=https://app.yourcompany.com
DATABASE_URL=postgresql://talentrank:change_me@postgres:5432/talentrank
TALENTRANK_USE_PRISMA=true

TALENTRANK_AUTH_SECRET=replace_with_32_plus_random_bytes
TALENTRANK_BOOTSTRAP_EMAIL=admin@yourcompany.com
TALENTRANK_BOOTSTRAP_PASSWORD=temporary_first_admin_password_rotate_after_setup

TALENTRANK_STORAGE_KEY=replace_with_32_plus_random_bytes
TALENTRANK_STORAGE_PROVIDER=external
TALENTRANK_STORAGE_UPLOAD_URL=https://storage-gateway.example.com/upload
TALENTRANK_STORAGE_DOWNLOAD_URL=https://storage-gateway.example.com/signed-download
TALENTRANK_STORAGE_TOKEN=replace_if_gateway_requires_bearer
# Alternative S3/R2/GCS-compatible storage:
# TALENTRANK_STORAGE_PROVIDER=s3
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_BUCKET=talentrank-resumes
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_SIGNED_URL_TTL_SECONDS=300

TALENTRANK_MALWARE_SCAN_URL=https://scanner.example.com/scan
TALENTRANK_MALWARE_SCAN_KEY=replace_if_scanner_requires_bearer
# Alternative malware provider:
# TALENTRANK_MALWARE_PROVIDER=virustotal
# VIRUSTOTAL_API_KEY=...

OCR_PROVIDER=generic
OCR_API_URL=https://ocr.example.com/extract
OCR_API_KEY=replace_if_ocr_requires_bearer
# Alternative direct provider:
# OCR_PROVIDER=ocrspace
# OCR_SPACE_API_KEY=your_ocr_space_api_key
# OCR_SPACE_LANGUAGE=eng
# OCR_SPACE_ENGINE=2

OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=256
TALENTRANK_MAX_BATCH_FILES=50
TALENTRANK_BACKUP_URL=https://backup-gateway.example.com/upload
TALENTRANK_RETENTION_DAYS=365
TALENTRANK_LOG_DRAIN_URL=https://logs.example.com/ingest
TALENTRANK_LOG_DRAIN_TOKEN=optional_bearer_token

TALENTRANK_EMAIL_PROVIDER=resend
TALENTRANK_EMAIL_FROM=TalentRank AI <noreply@yourcompany.com>
TALENTRANK_EMAIL_TEST_TO=ops@yourcompany.com
RESEND_API_KEY=...
# Alternatives:
# TALENTRANK_EMAIL_PROVIDER=postmark
# POSTMARK_SERVER_TOKEN=...
# TALENTRANK_EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=...
# TALENTRANK_EMAIL_PROVIDER=webhook
# TALENTRANK_EMAIL_WEBHOOK_URL=https://email-gateway.example.com/send
# TALENTRANK_EMAIL_WEBHOOK_TOKEN=optional_bearer_token

OIDC_ISSUER_URL=https://accounts.google.com
OIDC_CLIENT_ID=...
OIDC_CLIENT_SECRET=...
OIDC_DEFAULT_ORG_ID=org_demo
OIDC_DEFAULT_ROLE=recruiter
